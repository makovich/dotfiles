[main]
Find = alt-f7; f55; ctrl-f
Quit = alt-x; f10

[panel]
Up = up; k
Down = down; j
Left =
Right =
Top = alt-lt; home; left; g
Bottom = alt-gt; end; right; G
PageUp = pgup; ctrl-u; K
PageDown = pgdn; ctrl-d; J
CdParent = ctrl-pgup; backspace; h
Enter = enter; ctrl-j; l

MarkDown = space

Search = alt-slash; alt-s; ctrl-s
